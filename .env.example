# ============================================================
# Environment variable template for PythonAnywhere deployment
# Copy this file to .env for local development ONLY.
# On PythonAnywhere: set these in the "Environment variables"
# section of the Web tab — do NOT commit a real .env to git.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
# Set to false in production. Leaving it true disables CSRF,
# HTTPS-only cookies, and security header enforcement.
DEBUG=false

# Required: signals production mode (checked by production_config.py)
ENVIRONMENT=production

# Flask session signing key — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_generate_a_random_48char_token

# Admin panel login password (must not be a weak placeholder)
ADMIN_PASSWORD=CHANGE_ME_strong_password_here

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string. On PythonAnywhere use the
# "Databases" tab to create a Postgres DB and get this URL.
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── AI Providers ─────────────────────────────────────────────
# At least one of these must be set for AI responses to work.
CLAUDE_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── SMS / Telephony ──────────────────────────────────────────
# Your SMS gateway credentials (provider-specific)
SMS_GATEWAY_URL=https://your-sms-gateway.example.com/send
SMS_GATEWAY_API_KEY=your_gateway_api_key
SMS_ENCRYPTION_KEY=your_fernet_key_base64  # generate: from cryptography.fernet import Fernet; Fernet.generate_key()

# ── Security ─────────────────────────────────────────────────
# Comma-separated list of trusted proxy IPs (PythonAnywhere's
# reverse proxy IPs). Allows correct X-Forwarded-For parsing.
TRUSTED_PROXY_IPS=

# Comma-separated allowlist of domains for deposit media URLs.
# Example: s3.amazonaws.com,cdn.example.com
DEPOSIT_MEDIA_ALLOWED_HOSTS=

# Secret token for the /deploy auto-deploy webhook endpoint.
# Leave blank to disable the endpoint.
UPLOAD_SECRET=

# ── Google Services (optional) ───────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_CALENDAR_CREDENTIALS_JSON=  # base64-encoded credentials.json content

# ── Redis (optional) ─────────────────────────────────────────
# For distributed rate limiting. Falls back to in-process if unset.
# Use rediss:// for TLS (Upstash, Redis Cloud, etc.)
REDIS_URL=

# ── Observability (optional) ─────────────────────────────────
SENTRY_DSN=

# ── Background Jobs ──────────────────────────────────────────
# Set to false to disable APScheduler background jobs.
# On PythonAnywhere, background jobs run fine in the WSGI worker.
RUN_STARTUP_BACKGROUND_JOBS=true

# ── Logging ──────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
